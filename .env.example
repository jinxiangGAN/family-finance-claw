# ─── Telegram ───
TELEGRAM_BOT_TOKEN=

# ─── LLM Provider ───
# Supported: openai, minimax, deepseek, qwen, custom
LLM_PROVIDER=minimax
LLM_API_KEY=
LLM_MODEL=abab6.5s-chat
# LLM_BASE_URL=              # Override for custom endpoints
# LLM_VISION_MODEL=          # Vision model for receipt OCR (defaults to LLM_MODEL)
# LLM_EMBEDDING_MODEL=       # Embedding model for vector memory (leave empty → FTS5 only)

# Monthly token limit (0 = unlimited)
LLM_MONTHLY_TOKEN_LIMIT=500000

# ─── Database ───
DATABASE_PATH=data/expenses.db

# ─── Access Control ───
# Comma-separated Telegram user IDs (leave empty to allow all)
ALLOWED_USER_IDS=

# Family members: user_id:display_name (comma-separated)
# Example: FAMILY_MEMBERS=123456:Husband,789012:Wife
FAMILY_MEMBERS=

# ─── Locale ───
TIMEZONE=Asia/Singapore
LOCATION=Singapore
CURRENCY=SGD

# ─── Scheduler ───
# Weekly summary (0=Monday, 6=Sunday)
WEEKLY_SUMMARY_DAY=6
WEEKLY_SUMMARY_HOUR=20

# ─── Memory Settings ───
MEMORY_MAX_WORKING=10     # Max conversation turns in working memory
MEMORY_RECALL_TOP_K=3     # Top-K episodic memories to recall per query
