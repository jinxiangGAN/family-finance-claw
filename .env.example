# Telegram Bot Token (required)
TELEGRAM_BOT_TOKEN=

# MiniMax API (optional — falls back to regex parser if not set)
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_MODEL=abab6.5s-chat

# MiniMax monthly token limit (0 = unlimited, default 500000 ≈ ¥0.5)
MINIMAX_MONTHLY_TOKEN_LIMIT=500000

# Database path
DATABASE_PATH=data/expenses.db

# Allowed Telegram user IDs (comma-separated, leave empty to allow all)
ALLOWED_USER_IDS=

# Family members mapping: user_id:display_name (comma-separated)
# Example: FAMILY_MEMBERS=123456:老公,789012:老婆
FAMILY_MEMBERS=

# Timezone
TIMEZONE=Asia/Singapore

# Default currency
CURRENCY=SGD

# Weekly summary schedule (0=Monday, 6=Sunday)
WEEKLY_SUMMARY_DAY=6
WEEKLY_SUMMARY_HOUR=20
