# ═══════════════════════════════════════════
#  Family Finance Claw 🦞 — 环境变量配置
# ═══════════════════════════════════════════
#  复制为 .env 后填入你的真实值:
#    cp .env.example .env
# ═══════════════════════════════════════════

# ─── 必填 ───

# Telegram Bot Token (从 @BotFather 获取)
TELEGRAM_BOT_TOKEN=

# ─── 本地 Codex 配置 ───

# 当前版本默认走 Telegram -> 本地 Codex CLI，不再直接请求外部 LLM API
BOT_BACKEND=codex

# Codex 可执行文件路径
CODEX_BIN=codex

# 可选：指定 Codex 模型；留空则使用本机 Codex 默认模型
# CODEX_MODEL=gpt-5.4

# 可选：指定 Codex profile
# CODEX_PROFILE=

# 可选：当前默认 assistant 的稳定标识和显示名
# 后续如果你在外层再接多个 repo/多个助手，可以复用这两个字段做路由
# DEFAULT_ASSISTANT_ID=family-finance
# DEFAULT_ASSISTANT_NAME=小灰毛

# 未来如果在同一个外层服务里挂多个助手，
# Telegram 文本可以预留这些显式路由形式：
#   @family-finance 这个月花了多少
#   assistant:family-finance 本月汇总
#   /assistant family-finance 看看最近5笔
#
# 如果后面要把多个 repo/多个助手配置化接入，
# 可以提供一个 JSON 配置文件路径：
# ASSISTANT_REGISTRY_PATH=/home/your-user/family-finance-claw/data/assistants.json

# 可选：指定运行 bridge_ops 时使用的 Python 解释器
# 本机运行时建议填当前虚拟环境/conda 环境的 python 绝对路径
# 例如: PYTHON_BIN=/home/your-user/miniconda3/envs/py311/bin/python
# Docker 中通常不需要额外设置
# PYTHON_BIN=

# 单次处理超时时间（秒）
CODEX_TIMEOUT_SECONDS=180

# Codex runtime mode
# auto: prefer app-server, fall back to exec/resume
# app-server: force the resident app-server runtime
# exec: use the old per-turn CLI path
# CODEX_RUNTIME_MODE=auto

# Service tier for app-server thread startup
# CODEX_SERVICE_TIER=fast

# Codex 工作目录
# Docker 里通常是 /app
# 本机直接运行时请改成你的 repo 绝对路径
# 例如: CODEX_WORKDIR=/home/your-user/family-finance-claw
# CODEX_WORKDIR=/app

# Codex 认证与状态目录
# 生产环境建议先在同版本 Codex CLI 上执行一次 `codex login`，
# 再把生成的 ~/.codex 整个目录挂载到容器里的 CODEX_HOME。
# 例如 docker-compose 默认挂载到 /codex-home。
# 本机直接运行时建议填 repo 内的 codex-home 绝对路径
# 例如: CODEX_HOME=/home/your-user/family-finance-claw/codex-home
# CODEX_HOME=/codex-home

# ─── 家庭成员 ───

# Telegram User ID，逗号分隔 (留空则不限制)
# 获取方式: 给 @userinfobot 发消息即可看到你的 ID
ALLOWED_USER_IDS=

# 家庭成员映射: user_id:显示名  (逗号分隔)
# 例: FAMILY_MEMBERS=123456:老公,789012:老婆
FAMILY_MEMBERS=

# ─── 地区与货币 ───

TIMEZONE=Asia/Singapore
LOCATION=Singapore
CURRENCY=SGD

# ─── 可选 ───

# SQLite 数据库路径
# Docker 中通常是 /app/data/expenses.db
# 本机直接运行时建议填绝对路径
# 例如: DATABASE_PATH=/home/your-user/family-finance-claw/data/expenses.db
# DATABASE_PATH=data/expenses.db

# Codex thread/session 映射存储路径
# 用于把 Telegram chat 绑定到可恢复的 Codex thread id
# Docker 中通常也可以放在 /app/data 下
# 例如: CODEX_SESSION_STORE_PATH=/home/your-user/family-finance-claw/data/codex_sessions.json
# CODEX_SESSION_STORE_PATH=data/codex_sessions.json

# 周报: 星期几发送 (0=周一, 6=周日)
# WEEKLY_SUMMARY_DAY=6
# WEEKLY_SUMMARY_HOUR=20

# 记忆设置
# MEMORY_MAX_WORKING=10
# MEMORY_RECALL_TOP_K=3
