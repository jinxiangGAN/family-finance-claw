# ═══════════════════════════════════════════
#  Family Finance Claw 🦞 — 环境变量配置
# ═══════════════════════════════════════════
#  复制为 .env 后填入你的真实值:
#    cp .env.example .env
# ═══════════════════════════════════════════

# ─── 必填 ───

# Telegram Bot Token (从 @BotFather 获取)
TELEGRAM_BOT_TOKEN=

# LLM API Key (不填则只有正则兜底，无智能功能)
LLM_API_KEY=

# ─── LLM 配置 ───

# 支持: openai / minimax / deepseek / qwen / gemini / custom
# 推荐 Gemini（Google AI Studio 免费额度大）
LLM_PROVIDER=gemini
LLM_MODEL=gemini-3-flash-preview

# Vision 模型 (收据 OCR 用，留空则和 LLM_MODEL 相同)
# LLM_VISION_MODEL=

# Embedding 模型 (向量记忆检索，留空则用 FTS5 全文检索兜底)
# Gemini 可用: text-embedding-004
# LLM_EMBEDDING_MODEL=text-embedding-004

# 自定义 API 端点 (仅 custom provider 需要)
# LLM_BASE_URL=https://your-endpoint.com/v1

# 每月 Token 上限 (0 = 不限)
LLM_MONTHLY_TOKEN_LIMIT=0

# ─── 家庭成员 ───

# Telegram User ID，逗号分隔 (留空则不限制)
# 获取方式: 给 @userinfobot 发消息即可看到你的 ID
ALLOWED_USER_IDS=

# 家庭成员映射: user_id:显示名  (逗号分隔)
# 例: FAMILY_MEMBERS=123456:老公,789012:老婆
FAMILY_MEMBERS=

# ─── 地区与货币 ───

TIMEZONE=Asia/Singapore
LOCATION=Singapore
CURRENCY=SGD

# ─── 可选 ───

# SQLite 数据库路径
# DATABASE_PATH=data/expenses.db

# 周报: 星期几发送 (0=周一, 6=周日)
# WEEKLY_SUMMARY_DAY=6
# WEEKLY_SUMMARY_HOUR=20

# 记忆设置
# MEMORY_MAX_WORKING=10
# MEMORY_RECALL_TOP_K=3
