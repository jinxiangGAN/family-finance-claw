# ═══════════════════════════════════════════
#  Family Finance Claw 🦞 — 环境变量配置
# ═══════════════════════════════════════════
#  复制为 .env 后填入你的真实值:
#    cp .env.example .env
# ═══════════════════════════════════════════

# ─── 必填 ───

# Telegram Bot Token (从 @BotFather 获取)
TELEGRAM_BOT_TOKEN=

# ─── 本地 Codex 配置 ───

# 当前版本默认走 Telegram -> 本地 Codex CLI，不再直接请求外部 LLM API
BOT_BACKEND=codex

# Codex 可执行文件路径
CODEX_BIN=codex

# 可选：指定 Codex 模型；留空则使用本机 Codex 默认模型
# CODEX_MODEL=gpt-5.4

# 可选：指定 Codex profile
# CODEX_PROFILE=

# 单次处理超时时间（秒）
CODEX_TIMEOUT_SECONDS=180

# Codex 工作目录
# 本项目在 Docker / GCP 部署时建议固定为 /app，不需要改
# CODEX_WORKDIR=/app

# Codex 认证与状态目录
# 生产环境建议先在同版本 Codex CLI 上执行一次 `codex login`，
# 再把生成的 ~/.codex 整个目录挂载到容器里的 CODEX_HOME。
# 例如 docker-compose 默认挂载到 /codex-home。
# CODEX_HOME=/codex-home

# ─── 家庭成员 ───

# Telegram User ID，逗号分隔 (留空则不限制)
# 获取方式: 给 @userinfobot 发消息即可看到你的 ID
ALLOWED_USER_IDS=

# 家庭成员映射: user_id:显示名  (逗号分隔)
# 例: FAMILY_MEMBERS=123456:老公,789012:老婆
FAMILY_MEMBERS=

# ─── 地区与货币 ───

TIMEZONE=Asia/Singapore
LOCATION=Singapore
CURRENCY=SGD

# ─── 可选 ───

# SQLite 数据库路径
# DATABASE_PATH=data/expenses.db

# 周报: 星期几发送 (0=周一, 6=周日)
# WEEKLY_SUMMARY_DAY=6
# WEEKLY_SUMMARY_HOUR=20

# 记忆设置
# MEMORY_MAX_WORKING=10
# MEMORY_RECALL_TOP_K=3
